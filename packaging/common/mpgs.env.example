# MPGS server environment template (do not commit real secrets).
# Copy to a path outside the package (e.g. /etc/mpgs/mpgs.env or C:\ProgramData\MPGS\mpgs.env)
# and reference it from the service unit / WinSW envFile.

# Required for a persistent catalog
MPGS_DATABASE_PATH=/var/lib/mpgs/mpgs.db
# Windows example:
# MPGS_DATABASE_PATH=C:\ProgramData\MPGS\data\mpgs.db

# Bind address. Default is loopback only; put a reverse proxy in front for HTTPS.
MPGS_BIND_ADDR=127.0.0.1:17880

# Admin / internal jobs (required for /admin and /internal). Use a long random secret.
MPGS_ADMIN_TOKEN=

# Demo seed writes fictional catalog rows. Must stay false/absent in production.
# MPGS_SEED_DEMO=false

# AI (optional). Leave disabled unless a provider Key is configured.
MPGS_AI_PROVIDER=disabled
# MPGS_AI_API_KEY=
# MPGS_AI_BASE_URL=https://api.openai.com/v1
# MPGS_AI_MODEL=gpt-4o-mini
# MPGS_AI_TIMEOUT_SECS=12

# Embeddings (optional; hash is local and offline-safe)
MPGS_AI_EMBED_PROVIDER=hash
# MPGS_AI_EMBED_MODEL=text-embedding-3-small
# MPGS_AI_EMBED_DIMENSIONS=1536

# Rate limits (defaults are safe for local MVP)
# MPGS_RATE_LIMIT_ENABLED=true
# MPGS_TRUST_PROXY_HEADERS=false

# CORS for desktop clients (defaults cover Tauri webview origins). If this is
# overridden for a browser UI, retain http://tauri.localhost and
# tauri://localhost in the comma-separated list.
# MPGS_CORS_ENABLED=true
# MPGS_CORS_ALLOWED_ORIGINS=http://tauri.localhost,tauri://localhost,https://mpgs.example.com

# Logging
# RUST_LOG=info
